# ── HuggingFace API tokens ────────────────────────────────────────────────────
# All LLM inference goes through HuggingFace router (no Gemini / no OpenAI)
# Get your token at: https://huggingface.co/settings/tokens

# Primary token — used for Qwen2.5-72B analysis (all 5 board agents)
HF_TOKEN=hf_your_token_here

# Optional: secondary token for fast Llama-3.1-8B extraction calls
# If not set, falls back to HF_TOKEN automatically
HF_DECISION_TOKEN=hf_your_token_here
